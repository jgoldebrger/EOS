# @supabase/server — copy real values from Supabase Dashboard → Connect
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Next.js browser client (@supabase/ssr)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Legacy alias (optional) — prefer SUPABASE_SECRET_KEY for server code
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# OAuth provider toggles (configure providers in Supabase Auth dashboard)
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false

# E2E testing (optional — enable authenticated Playwright flows)
# Requires: supabase start && supabase db reset (Docker)
# E2E_SUPABASE_ENABLED=1
# E2E_ORG_SLUG=demo
# E2E_VIEWER_ORG_SLUG=demo-viewer
# E2E_ADMIN_EMAIL=admin@demo.local
# E2E_ADMIN_PASSWORD=E2eTestPassword1!
# E2E_MEETING_ID=55555555-5555-5555-5555-555555555555
