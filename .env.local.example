# =============================================================================
# SOP — Environment variables
# Copy to `.env.local` and fill values from Supabase Dashboard → Connect
# =============================================================================

# --- Required: Supabase (server) ---
# Used by @supabase/server, server actions, and API route handlers.
# See lib/supabase/env.ts and lib/supabase/server-sdk.ts

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# --- Required: Supabase (browser) ---
# Used by @supabase/ssr in Next.js client components.
# Use the same project URL and publishable key as above.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# --- Optional: OAuth provider toggles ---
# Set to `true` to show the provider on /auth.
# Configure Google/Microsoft in Supabase Dashboard → Authentication → Providers first.

NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false

# --- Optional: legacy alias ---
# Prefer SUPABASE_SECRET_KEY for server code. Only needed if migrating old config.

# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Optional: cloud DB migrations ---
# Only for scripts/push-cloud-db.ps1 (not needed for `npm run dev`).
# Find password: Supabase Dashboard → Project Settings → Database → Database password

# SUPABASE_DB_PASSWORD=

# --- Optional: E2E testing (Playwright) ---
# Requires Docker + `supabase start` and `supabase db reset` so seed.sql creates test data.
# Smoke tests run without these; authenticated flows need E2E_SUPABASE_ENABLED=1.

# E2E_SUPABASE_ENABLED=1
# E2E_ORG_SLUG=demo
# E2E_VIEWER_ORG_SLUG=demo-viewer
# E2E_ADMIN_EMAIL=admin@demo.local
# E2E_ADMIN_PASSWORD=E2eTestPassword1!
# E2E_VIEWER_EMAIL=viewer@demo.local
# E2E_VIEWER_PASSWORD=E2eTestPassword1!
# E2E_MEETING_ID=55555555-5555-5555-5555-555555555555
# E2E_OPENAI_ENABLED=1
