# Supabase public URL (browser + server)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon key (browser + server; safe with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the client or commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth provider toggles (configure providers in Supabase Auth dashboard)
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false

# E2E testing (optional — enable authenticated Playwright flows)
# E2E_SUPABASE_ENABLED=1
# E2E_ORG_SLUG=demo
# E2E_VIEWER_ORG_SLUG=demo-viewer
